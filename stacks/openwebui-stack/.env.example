# Copy to .env next to docker-compose.yml. Do not commit .env.
# Docker Compose reads this file for ${VAR} substitution and passes it to services that use env_file.

# --- Compose substitution (open-terminal, db, litellm DATABASE_URL) ---
OPEN_TERMINAL_API_KEY=change-me-to-a-long-random-secret
POSTGRES_PASSWORD=change-me-strong-db-password

# --- LiteLLM container (env_file; use in config.yaml as os.environ/NAME) ---
LITELLM_MASTER_KEY=sk-litellm-admin-key-change-me
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Open WebUI container (env_file) — optional; many settings are UI-only ---
# OPENAI_API_BASE_URL=http://litellm:4000/v1
# OPENAI_API_KEY=<LiteLLM virtual key or key policy from LiteLLM docs>
# WEBUI_SECRET_KEY=
